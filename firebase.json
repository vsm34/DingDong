{
  "firestore": {
    "database": "(default)",
    "location": "us-east1",
    "rules": "cloud/firestore.rules",
    "indexes": "firestore.indexes.json"
  },
"functions": [
  {
    "source": "cloud/functions",
    "codebase": "default",
    "runtime": "nodejs22",
    "disallowLegacyRuntimeConfig": true,
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*.local"
    ]
  }
]
}

